{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "${workspaceFolder}/frontend/node_modules/.bin/astro",
      "runtimeArgs": ["dev", "--port", "4321", "--host"],
      "cwd": "${workspaceFolder}/frontend",
      "port": 4321
    },
    {
      "name": "backend",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
      "port": 8000
    }
  ]
}
