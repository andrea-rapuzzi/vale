# Backend
ANTHROPIC_API_KEY=sk-ant-...

# Supabase Postgres connection string. Use the "Transaction pooler" URL from
# Supabase dashboard → Project Settings → Database → Connection pooling.
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# CORS origin for the frontend (production URL on Vercel)
FRONTEND_URL=http://localhost:4321

# Cookie source for yt-dlp. Set to "" in production (Railway has no browser).
COOKIES_BROWSER=chrome
COOKIES_DIR=./data

# Frontend (copy to frontend/.env)
BACKEND_URL=http://localhost:8000
PUBLIC_BACKEND_URL=http://localhost:8000
