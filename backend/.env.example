ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
FRONTEND_URL=http://localhost:4321

# Supabase Auth — Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Optional: max AI calls (ai_search + query_eval) per user per day; 0 = unlimited
DAILY_AI_CALL_LIMIT=0

# Optional: export browser cookies to bypass YouTube IP blocks
# COOKIES_BROWSER=chrome

# Optional: Webshare rotating proxy to bypass YouTube rate limits (recommended)
# Get credentials at https://dashboard.webshare.io/proxy/settings
# Requires a "Residential" plan — Proxy Server / Static Residential plans are blocked by YouTube
# WEBSHARE_PROXY_USERNAME=your-proxy-username
# WEBSHARE_PROXY_PASSWORD=your-proxy-password

# Optional: generic HTTP/HTTPS proxy fallback (if not using Webshare credentials above)
# YT_PROXY=http://user:pass@host:port
