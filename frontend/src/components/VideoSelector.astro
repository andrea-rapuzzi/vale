---
interface Props {
  videos: any[];
  channelId: string | undefined;
}
const { videos, channelId } = Astro.props;
const apiBase = import.meta.env.PUBLIC_BACKEND_URL ?? 'http://localhost:8000';
const scrapedCount = videos.filter((v: any) => v.scraped).length;
---
<div class="space-y-4">
  <div class="flex items-center justify-between gap-4">
    <p class="text-sm text-gray-400">Select up to <strong class="text-white">10 videos</strong> to scrape transcripts.</p>
    <div class="flex items-center gap-3 shrink-0">
      {scrapedCount > 0 && (
        <button
          id="scraped-toggle"
          class="text-xs px-2.5 py-1 rounded-md border border-green-700 text-green-400 hover:bg-green-900/40 transition-colors"
        >
          Show scraped ({scrapedCount})
        </button>
      )}
      <span id="sel-count" class="text-sm font-medium text-indigo-400">0 selected</span>
    </div>
  </div>

  <div class="space-y-2 max-h-[60vh] overflow-y-auto pr-1">
    {videos.map((v: any) => (
      <label
        data-scraped={v.scraped ? 'true' : 'false'}
        class={`flex items-start gap-3 px-4 py-3 rounded-lg cursor-pointer transition-colors group border-l-2 ${
          v.scraped
            ? 'bg-gray-900 border-green-700 hover:bg-gray-800'
            : 'bg-gray-900 border-transparent hover:bg-gray-800'
        }`}
      >
        <input
          type="checkbox"
          name="video"
          value={v.id}
          data-youtube-id={v.youtube_id}
          disabled={false}
          class="mt-0.5 accent-indigo-500 video-cb"
        />
        <div class="flex-1 min-w-0">
          <p class="text-sm text-gray-200 group-hover:text-white leading-snug">{v.title}</p>
          <p class="text-xs text-gray-500 mt-0.5">
            {v.upload_date ? `${v.upload_date.slice(0,4)}-${v.upload_date.slice(4,6)}-${v.upload_date.slice(6,8)}` : ''}
            {v.duration_sec ? ` · ${Math.floor(v.duration_sec/60)}m${v.duration_sec%60}s` : ''}
            {v.scraped && <span class="ml-2 inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full text-xs font-semibold bg-green-900/60 text-green-400 border border-green-700">✓ scraped</span>}
          </p>
        </div>
        {v.scraped && (
          <a
            href={`/video/${v.id}`}
            onclick="event.stopPropagation()"
            class="shrink-0 inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-xs font-medium text-indigo-300 bg-indigo-900/40 border border-indigo-800 hover:bg-indigo-900/60 hover:text-indigo-200"
          >
            View transcript →
          </a>
        )}
      </label>
    ))}
  </div>

  <div class="flex gap-3 pt-2">
    <button
      id="scrape-btn"
      disabled
      class="px-5 py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
    >
      Scrape Selected
    </button>
    <button
      id="compare-btn"
      disabled
      class="px-5 py-2.5 rounded-lg bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
      title="Compare transcripts of 2–3 already-scraped videos"
    >
      Compare
    </button>
  </div>

  <p id="sel-error" class="text-sm text-red-400 hidden"></p>
</div>

<script define:vars={{ apiBase, scrapedCount }}>
  const checkboxes = document.querySelectorAll('.video-cb');
  const scrapeBtn = document.getElementById('scrape-btn');
  const compareBtn = document.getElementById('compare-btn');
  const countEl = document.getElementById('sel-count');
  const errEl = document.getElementById('sel-error');

  // Map video id → scraped status for compare eligibility
  const scrapedMap = {};
  document.querySelectorAll('input.video-cb').forEach(cb => {
    const label = cb.closest('label');
    scrapedMap[cb.value] = label?.dataset.scraped === 'true';
  });

  function getSelected() {
    return Array.from(checkboxes).filter(cb => cb.checked).map(cb => Number(cb.value));
  }

  function update() {
    const sel = getSelected();
    const count = sel.length;
    countEl.textContent = `${count} selected`;
    scrapeBtn.disabled = count === 0;

    // Enforce max 10: disable unchecked if already at limit
    checkboxes.forEach(cb => {
      if (!cb.checked) cb.disabled = count >= 10;
    });

    // Compare button: enabled when 2–3 scraped videos are selected
    const allScraped = sel.length >= 2 && sel.length <= 3 && sel.every(id => scrapedMap[id]);
    compareBtn.disabled = !allScraped;
  }

  checkboxes.forEach(cb => cb.addEventListener('change', update));

  // Scraped-only toggle
  const toggleBtn = document.getElementById('scraped-toggle');
  const allLabels = document.querySelectorAll('label[data-scraped]');
  let scrapedOnly = false;
  if (toggleBtn && scrapedCount > 0) {
    toggleBtn.addEventListener('click', () => {
      scrapedOnly = !scrapedOnly;
      allLabels.forEach(label => {
        const isScraped = label.dataset.scraped === 'true';
        label.style.display = scrapedOnly && !isScraped ? 'none' : '';
      });
      toggleBtn.textContent = scrapedOnly ? `Show all` : `Show scraped (${scrapedCount})`;
      toggleBtn.classList.toggle('bg-green-900/40', scrapedOnly);
    });
  }

  compareBtn.addEventListener('click', () => {
    const ids = getSelected();
    if (ids.length < 2) return;
    const params = ids.map(id => `v=${id}`).join('&');
    window.location.href = `/compare?${params}&mode=classic`;
  });

  scrapeBtn.addEventListener('click', async () => {
    const ids = getSelected();
    if (!ids.length) return;
    errEl.classList.add('hidden');
    scrapeBtn.disabled = true;
    scrapeBtn.textContent = 'Starting…';
    try {
      const res = await fetch(`${apiBase}/api/scrape`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${await window.__getAuthToken()}` },
        body: JSON.stringify({ video_ids: ids }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.detail ?? 'Error starting scrape');
      const videoParams = ids.map(id => `v=${id}`).join('&');
      window.location.href = `/scrape/${data.job_id}?${videoParams}`;
    } catch (e) {
      errEl.textContent = e.message;
      errEl.classList.remove('hidden');
      scrapeBtn.disabled = false;
      scrapeBtn.textContent = 'Scrape Selected';
    }
  });

</script>
