---
import '../styles/global.css';
import { t } from '../lib/i18n';
interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}
const { title = 'VALE', description = 'VALE — search across YouTube video transcripts with AI-powered semantic analysis.', canonicalPath } = Astro.props;
const accessToken = Astro.locals.accessToken ?? ''
const userEmail = Astro.locals.userEmail ?? ''
const sessionToken = Astro.locals.sessionToken ?? ''
const lang = Astro.locals.lang ?? 'en'
const isLoggedIn = !!accessToken
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://vale.app';
const pageTitle = title === 'VALE' ? 'VALE' : `${title} — VALE`;
const canonicalUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : null;
---
<!doctype html>
<html lang={lang} class="bg-gray-950 text-gray-100 min-h-screen">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VALE" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:image" content={`${siteUrl}/open-graph-image.jpg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/open-graph-image.jpg`} />
    <script define:vars={{ accessToken, sessionToken }}>
      window.__authToken = accessToken
      window.__sessionToken = sessionToken
    </script>
  </head>
  <body class="min-h-screen flex flex-col pb-[env(safe-area-inset-bottom)]">
    <style>
      @keyframes logo-in {
        from { opacity: 0; transform: scale(0.96); }
        to   { opacity: 0.8; transform: scale(1); }
      }
      .logo-img {
        animation: logo-in 0.5s ease-out forwards;
        transition: opacity 0.25s ease, transform 0.25s ease, filter 0.25s ease;
      }
      .logo-img:hover {
        opacity: 1 !important;
        transform: scale(1.05);
        filter: drop-shadow(0 0 10px rgba(124, 58, 237, 0.75));
      }
    </style>
    <header class="border-b border-gray-800 px-6 py-4 flex items-center gap-6">
      <a href="/" class="flex items-center">
        <img src="/logo.svg" alt="VALE" class="h-4 logo-img" />
      </a>
      <nav class="flex gap-4 text-sm text-gray-400">
        <a href="/channels" class="hover:text-white transition-colors">{t(lang, 'nav.channels')}</a>
        <a href="/library" class="hover:text-white transition-colors">{t(lang, 'nav.library')}</a>
        {isLoggedIn && <a href="/my" class="hover:text-white transition-colors">{t(lang, 'nav.myLibrary')}</a>}
        <a href="/settings" class="hover:text-white transition-colors">{t(lang, 'nav.settings')}</a>
      </nav>
      <div class="ml-auto flex items-center gap-4">
        {userEmail && <span class="text-xs text-gray-500 hidden sm:block">{userEmail}</span>}
        {isLoggedIn ? (
          <button id="logout-btn" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">
            {t(lang, 'nav.signOut')}
          </button>
        ) : (
          <a href="/login" class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors">
            {t(lang, 'nav.signIn')}
          </a>
        )}
      </div>
    </header>
    <main class="flex-1 px-6 py-8 max-w-5xl mx-auto w-full">
      <slot />
    </main>
  </body>
</html>

<script>
  import { createClient } from '../lib/supabase'
  const _supabase = createClient()
  window.__getAuthToken = async () => {
    const { data: { session } } = await _supabase.auth.getSession()
    return session?.access_token ?? window.__authToken ?? ''
  }
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await _supabase.auth.signOut()
    window.location.href = '/login'
  })
</script>
