---
import '../styles/global.css';
interface Props { title?: string }
const { title = 'VALE' } = Astro.props;
const accessToken = Astro.locals.accessToken ?? ''
const userEmail = Astro.locals.userEmail ?? ''
---
<!doctype html>
<html lang="en" class="bg-gray-950 text-gray-100 min-h-screen">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title} — VALE</title>
    <script define:vars={{ accessToken }}>window.__authToken = accessToken</script>
  </head>
  <body class="min-h-screen flex flex-col pb-[env(safe-area-inset-bottom)]">
    <header class="border-b border-gray-800 px-6 py-4 flex items-center gap-6">
      <a href="/" class="text-lg font-bold tracking-tight text-white hover:text-indigo-400 transition-colors">
        VALE
      </a>
      <nav class="flex gap-4 text-sm text-gray-400">
        <a href="/channels" class="hover:text-white transition-colors">Channels</a>
        <a href="/library" class="hover:text-white transition-colors">Library</a>
      </nav>
      <div class="ml-auto flex items-center gap-4">
        {userEmail && <span class="text-xs text-gray-500 hidden sm:block">{userEmail}</span>}
        <button id="logout-btn" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">
          Sign out
        </button>
      </div>
    </header>
    <main class="flex-1 px-6 py-8 max-w-5xl mx-auto w-full">
      <slot />
    </main>
  </body>
</html>

<script>
  import { createClient } from '../lib/supabase'
  const _supabase = createClient()
  window.__getAuthToken = async () => {
    const { data: { session } } = await _supabase.auth.getSession()
    return session?.access_token ?? window.__authToken ?? ''
  }
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await _supabase.auth.signOut()
    window.location.href = '/login'
  })
</script>
