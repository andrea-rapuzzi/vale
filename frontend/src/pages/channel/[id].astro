---
import Base from '../../layouts/Base.astro';
import VideoSelector from '../../components/VideoSelector.astro';
import { t } from '../../lib/i18n';

const { id } = Astro.params;
const lang = Astro.locals.lang ?? 'en';
const apiBase = import.meta.env.BACKEND_URL ?? 'http://localhost:8000';

let channel: any = null;
let videos: any[] = [];
let total = 0;
let scrapedCount = 0;
let error = '';

try {
  const res = await fetch(`${apiBase}/api/channel/${id}/videos?limit=200`);
  if (!res.ok) { error = t(lang, 'channel.notFound'); }
  else {
    const data = await res.json();
    channel = { id, name: data.channel_name };
    videos = data.videos;
    total = data.total;
    scrapedCount = data.scraped_count;
  }
} catch (e: any) {
  error = e.message;
}
---
<Base title={channel?.name ?? 'Channel'}>
  {error ? (
    <div class="text-red-400">{error}</div>
  ) : (
    <div class="space-y-6">
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-2xl font-bold text-white">{channel?.name}</h1>
          <p class="text-sm text-gray-400 mt-1">
            {t(lang, 'channel.videos', { total, scraped: scrapedCount })}
          </p>
        </div>
        <a href="/query" class="text-sm text-indigo-400 hover:text-indigo-300 transition-colors">
          {t(lang, 'channel.goToSearch')}
        </a>
      </div>

      <VideoSelector videos={videos} channelId={id} />
    </div>
  )}
</Base>
