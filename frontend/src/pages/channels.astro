---
import Base from '../layouts/Base.astro';
import { t } from '../lib/i18n';

const lang = Astro.locals.lang ?? 'en';
const publicApiBase = import.meta.env.PUBLIC_BACKEND_URL ?? import.meta.env.BACKEND_URL ?? 'http://localhost:8000';
---
<Base title={t(lang, 'channels.title')}>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold text-white">{t(lang, 'channels.title')}</h1>
      <p id="channels-subtitle" class="text-sm text-gray-400 mt-1">&nbsp;</p>
    </div>

    <div id="error-msg" class="hidden text-red-400 text-sm"></div>

    <div id="channels-skeleton" class="space-y-2">
      {Array.from({ length: 6 }).map(() => (
        <div class="h-12 rounded-lg bg-gray-900 animate-pulse" />
      ))}
    </div>

    <div id="filter-section" class="hidden space-y-2">
      <input
        id="filter"
        type="text"
        placeholder={t(lang, 'channels.filterPlaceholder')}
        class="w-full px-4 py-2.5 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm"
      />
      <ul id="channel-list" class="space-y-2 pt-2"></ul>
      <p id="empty-filter" class="hidden text-sm text-gray-500 pt-4">{t(lang, 'channels.emptyFilter')}</p>
    </div>

    <p id="empty-msg" class="hidden text-gray-400 text-sm" set:html={t(lang, 'channels.empty')} />

    <span
      id="i18n-data"
      class="hidden"
      data-api-base={publicApiBase}
      data-subtitle-singular={t(lang, 'channels.subtitle')}
      data-subtitle-plural={t(lang, 'channels.subtitle_plural')}
    />
  </div>
</Base>

<script>
  const i18n = (document.getElementById('i18n-data') as HTMLElement).dataset;
  const apiBase = i18n.apiBase!;

  function esc(s: unknown): string {
    return String(s ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  async function loadChannels() {
    const skeleton = document.getElementById('channels-skeleton');
    const filterSection = document.getElementById('filter-section');
    const emptyMsg = document.getElementById('empty-msg');
    const errorMsg = document.getElementById('error-msg');
    const subtitle = document.getElementById('channels-subtitle');
    const list = document.getElementById('channel-list');

    try {
      const res = await fetch(`${apiBase}/api/channels?limit=200`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const channels: any[] = data.channels ?? [];

      skeleton?.remove();

      if (channels.length === 0) {
        emptyMsg?.classList.remove('hidden');
        return;
      }

      if (subtitle) {
        const tpl = channels.length === 1 ? i18n.subtitleSingular! : i18n.subtitlePlural!;
        subtitle.textContent = tpl.replace('{{count}}', String(channels.length));
      }

      if (list) {
        list.innerHTML = channels
          .map(
            c => `
          <li class="channel-row" data-search="${esc((c.name ?? c.url ?? '').toLowerCase())}">
            <a href="/channel/${c.id}" class="flex items-center justify-between gap-4 px-4 py-3 rounded-lg bg-gray-900 hover:bg-gray-800 transition-colors group">
              <span class="text-sm text-gray-100 group-hover:text-white font-medium truncate">${esc(c.name ?? c.url)}</span>
              <span class="shrink-0 text-xs text-gray-500">
                <span class="${c.scraped_count > 0 ? 'text-green-400' : 'text-gray-500'}">${c.scraped_count}</span>/${c.video_count} scraped
                ${c.fetched_at ? `<span class="ml-2">· ${String(c.fetched_at).slice(0, 10)}</span>` : ''}
              </span>
            </a>
          </li>`,
          )
          .join('');
      }

      filterSection?.classList.remove('hidden');
    } catch (e: any) {
      skeleton?.remove();
      if (errorMsg) {
        errorMsg.textContent = e.message;
        errorMsg.classList.remove('hidden');
      }
    }
  }

  loadChannels();

  const input = document.getElementById('filter') as HTMLInputElement | null;
  const emptyFilter = document.getElementById('empty-filter');
  if (input) {
    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      const rows = document.querySelectorAll<HTMLElement>('.channel-row');
      let visible = 0;
      rows.forEach(row => {
        const hit = !q || (row.dataset.search ?? '').includes(q);
        row.style.display = hit ? '' : 'none';
        if (hit) visible++;
      });
      if (emptyFilter) emptyFilter.classList.toggle('hidden', visible !== 0);
    });
  }
</script>
