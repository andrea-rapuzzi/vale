---
import Base from '../layouts/Base.astro';

const apiBase = import.meta.env.BACKEND_URL ?? 'http://localhost:8000';

let channels: any[] = [];
let error = '';

try {
  const res = await fetch(`${apiBase}/api/channels?limit=200`);
  if (!res.ok) {
    error = `HTTP ${res.status}`;
  } else {
    const data = await res.json();
    channels = data.channels ?? [];
  }
} catch (e: any) {
  error = e.message;
}
---
<Base title="Channels">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold text-white">Channels</h1>
      <p class="text-sm text-gray-400 mt-1">
        {channels.length} {channels.length === 1 ? 'canale aggiunto' : 'canali aggiunti'} finora.
      </p>
    </div>

    {error && <div class="text-red-400 text-sm">Errore: {error}</div>}

    {!error && channels.length === 0 && (
      <p class="text-gray-400 text-sm">
        Nessun canale ancora. Vai sulla <a href="/" class="text-indigo-400 hover:text-indigo-300">home</a>
        e aggiungine uno.
      </p>
    )}

    {channels.length > 0 && (
      <div class="space-y-2">
        <input
          id="filter"
          type="text"
          placeholder="Filtra per nome canale…"
          class="w-full px-4 py-2.5 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm"
        />

        <ul id="channel-list" class="space-y-2 pt-2">
          {channels.map((c: any) => (
            <li
              class="channel-row"
              data-search={(c.name ?? c.url ?? '').toLowerCase()}
            >
              <a
                href={`/channel/${c.id}`}
                class="flex items-center justify-between gap-4 px-4 py-3 rounded-lg bg-gray-900 hover:bg-gray-800 transition-colors group"
              >
                <span class="text-sm text-gray-100 group-hover:text-white font-medium truncate">
                  {c.name ?? c.url}
                </span>
                <span class="shrink-0 text-xs text-gray-500">
                  <span class={c.scraped_count > 0 ? 'text-green-400' : 'text-gray-500'}>
                    {c.scraped_count}
                  </span>
                  /{c.video_count} scraped
                  {c.fetched_at && <span class="ml-2">· {c.fetched_at.slice(0, 10)}</span>}
                </span>
              </a>
            </li>
          ))}
        </ul>

        <p id="empty-filter" class="hidden text-sm text-gray-500 pt-4">Nessun canale corrisponde al filtro.</p>
      </div>
    )}
  </div>
</Base>

<script>
  const input = document.getElementById('filter') as HTMLInputElement | null;
  const empty = document.getElementById('empty-filter');
  if (input) {
    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      const rows = document.querySelectorAll<HTMLElement>('.channel-row');
      let visible = 0;
      rows.forEach(row => {
        const hit = !q || (row.dataset.search ?? '').includes(q);
        row.style.display = hit ? '' : 'none';
        if (hit) visible++;
      });
      if (empty) empty.classList.toggle('hidden', visible !== 0);
    });
  }
</script>
