---
import Base from '../../layouts/Base.astro';

const apiBase = import.meta.env.PUBLIC_BACKEND_URL ?? import.meta.env.BACKEND_URL ?? 'http://localhost:8000';
const videoIds = Astro.url.searchParams.getAll('v').map(Number).filter(Boolean);

const results = await Promise.allSettled(
  videoIds.map(id =>
    fetch(`${apiBase}/api/video/${id}/transcript`)
      .then(r => r.ok ? r.json() : Promise.reject(`HTTP ${r.status}`))
  )
);

const videos = results
  .filter((r): r is PromiseFulfilledResult<any> => r.status === 'fulfilled')
  .map(r => r.value);

const fetchErrors = results
  .filter((r): r is PromiseRejectedResult => r.status === 'rejected')
  .map(r => String(r.reason));

const totalChunks = videos.reduce((n: number, v: any) => n + v.chunks.length, 0);
const multiVideo = videos.length > 1;
const queryLink = `/query?${videoIds.map(id => `v=${id}`).join('&')}`;

function fmtTime(s: number) {
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  const sec = Math.floor(s % 60);
  if (h) return `${h}:${String(m).padStart(2, '0')}:${String(sec).padStart(2, '0')}`;
  return `${m}:${String(sec).padStart(2, '0')}`;
}
---
<Base title="Chunk Browser">
  <div class="max-w-3xl mx-auto space-y-6">

    {videoIds.length === 0 ? (
      <div class="text-center py-16 space-y-3">
        <p class="text-gray-400">No videos selected.</p>
        <a href="/" class="text-sm text-indigo-400 hover:text-indigo-300">← Go home</a>
      </div>
    ) : (
      <>
        {/* Header */}
        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <button onclick="history.back()" class="text-xs text-gray-500 hover:text-gray-300 transition-colors cursor-pointer">← Back</button>
            </div>
            <h1 class="text-2xl font-bold text-white">Chunk Browser</h1>
            <p class="text-sm text-gray-400 mt-1">
              {multiVideo
                ? `${videos.length} videos`
                : videos[0]?.title ?? 'Loading…'}
              <span class="mx-2 text-gray-600">·</span>
              <span id="chunk-count">{totalChunks}</span> chunks
            </p>
          </div>
          {videos.length > 0 && (
            <a
              href={queryLink}
              class="shrink-0 px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium transition-colors"
            >
              Run AI Search →
            </a>
          )}
        </div>

        {/* Fetch errors */}
        {fetchErrors.length > 0 && (
          <div class="space-y-1">
            {fetchErrors.map(e => (
              <p class="text-xs text-yellow-400">⚠ Failed to load a video: {e}</p>
            ))}
          </div>
        )}

        {videos.length === 0 ? (
          <p class="text-gray-400 text-sm">Could not load any transcript data.</p>
        ) : (
          <>
            {/* Sticky search bar */}
            <div class="sticky top-0 z-10 bg-gray-950 py-3 border-b border-gray-800">
              <div class="relative flex items-center gap-3">
                <div class="relative flex-1">
                  <input
                    id="search-input"
                    type="text"
                    placeholder="Filter chunks…"
                    autocomplete="off"
                    class="w-full px-4 py-2.5 pr-9 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm"
                  />
                  <button
                    id="clear-btn"
                    style="display:none"
                    class="absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-300 text-lg leading-none"
                    aria-label="Clear search"
                  >×</button>
                </div>
                <span id="match-count" class="shrink-0 text-xs text-gray-500 w-20 text-right"></span>
              </div>
            </div>

            {/* Chunk list */}
            <div id="chunk-list" class="space-y-1">
              {videos.map((v: any) => (
                <>
                  {multiVideo && (
                    <h2
                      data-group-id={String(v.video_id)}
                      class="text-sm font-semibold text-indigo-400 pt-4 pb-1 first:pt-0"
                    >
                      {v.title}
                    </h2>
                  )}
                  {v.chunks.map((c: any) => (
                    <div
                      class="chunk-row flex gap-4 px-4 py-3 rounded-lg bg-gray-900 hover:bg-gray-800 transition-colors"
                      data-text={c.text.toLowerCase()}
                      data-group={String(v.video_id)}
                    >
                      <a
                        href={`https://www.youtube.com/watch?v=${v.youtube_id}&t=${Math.floor(c.start_sec)}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="shrink-0 font-mono text-xs text-indigo-400 hover:text-indigo-300 pt-0.5 w-14"
                      >
                        {fmtTime(c.start_sec)}
                      </a>
                      <p
                        class="chunk-text text-sm text-gray-200 leading-relaxed flex-1"
                        data-raw={c.text}
                      >{c.text}</p>
                    </div>
                  ))}
                </>
              ))}
            </div>

            <p id="no-results" class="hidden text-sm text-gray-500 text-center py-8">
              No chunks match your search.
            </p>
          </>
        )}
      </>
    )}
  </div>
</Base>

<script define:vars={{ multiVideo }}>
  const input = document.getElementById('search-input');
  const clearBtn = document.getElementById('clear-btn');
  const matchCount = document.getElementById('match-count');
  const noResults = document.getElementById('no-results');
  const rows = document.querySelectorAll('.chunk-row');

  function escapeHtml(str) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function filter() {
    const q = input.value.trim().toLowerCase();
    let visible = 0;

    rows.forEach(row => {
      const text = row.dataset.text;
      const matches = !q || text.includes(q);
      row.style.display = matches ? '' : 'none';

      const textEl = row.querySelector('.chunk-text');
      if (q && matches) {
        const raw = textEl.dataset.raw;
        const idx = raw.toLowerCase().indexOf(q);
        if (idx !== -1) {
          textEl.innerHTML =
            escapeHtml(raw.slice(0, idx)) +
            `<mark class="bg-yellow-400/30 text-yellow-200 rounded px-0.5">${escapeHtml(raw.slice(idx, idx + q.length))}</mark>` +
            escapeHtml(raw.slice(idx + q.length));
        }
      } else {
        textEl.textContent = textEl.dataset.raw;
      }

      if (matches) visible++;
    });

    if (multiVideo) {
      document.querySelectorAll('[data-group-id]').forEach(header => {
        const gid = header.dataset.groupId;
        const anyVisible = Array.from(rows).some(
          r => r.dataset.group === gid && r.style.display !== 'none'
        );
        header.style.display = anyVisible ? '' : 'none';
      });
    }

    matchCount.textContent = q ? `${visible} match${visible !== 1 ? 'es' : ''}` : '';
    clearBtn.style.display = q ? '' : 'none';
    if (noResults) noResults.classList.toggle('hidden', !q || visible > 0);
  }

  if (input) {
    input.addEventListener('input', filter);
    clearBtn.addEventListener('click', () => { input.value = ''; filter(); input.focus(); });
  }
</script>
