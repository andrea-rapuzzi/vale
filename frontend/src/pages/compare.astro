---
import Base from '../layouts/Base.astro';

const apiBase = import.meta.env.BACKEND_URL ?? 'http://localhost:8000';
const publicApiBase = import.meta.env.PUBLIC_BACKEND_URL ?? 'http://localhost:8000';

const rawIds = Astro.url.searchParams.getAll('v').slice(0, 3);
const videoIds = rawIds.map(Number).filter(id => id > 0);

if (videoIds.length < 2) {
  return Astro.redirect('/library');
}

type Chunk = { index: number; start_sec: number; end_sec: number; text: string };
type VideoData = {
  id: number;
  youtube_id: string;
  title: string;
  channel_name: string;
  chunk_count: number;
  duration_sec: number | null;
  chunks: Chunk[];
};

const videos: VideoData[] = [];
for (const id of videoIds) {
  try {
    const res = await fetch(`${apiBase}/api/video/${id}/transcript`);
    if (res.ok) {
      const d = await res.json();
      videos.push({
        id,
        youtube_id: d.youtube_id,
        title: d.title,
        channel_name: d.channel_name ?? '',
        chunk_count: d.chunks?.length ?? 0,
        duration_sec: d.duration_sec ?? null,
        chunks: d.chunks ?? [],
      });
    }
  } catch {}
}

if (videos.length < 2) {
  return Astro.redirect('/library');
}

function fmtTime(s: number) {
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  const sec = Math.floor(s % 60);
  if (h) return `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
  return `${m}:${String(sec).padStart(2,'0')}`;
}
---
<Base title="Compare Transcripts">
  <div class="space-y-4">

    <div class="flex items-center gap-4">
      <a href="/library" class="text-sm text-gray-500 hover:text-gray-300 transition-colors">← Library</a>
      <h1 class="text-xl font-bold text-white">Compare Transcripts</h1>
    </div>

    <!-- Shared sticky filter bar -->
    <div class="sticky top-0 z-20 bg-gray-950 py-3 border-b border-gray-800 space-y-2">
      <!-- Chunk filter row -->
      <div class="flex items-center gap-3">
        <div class="relative flex-1">
          <input
            id="filter-input"
            type="text"
            placeholder="Filter chunks across all videos…"
            autocomplete="off"
            class="w-full px-4 py-2.5 pr-9 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm"
          />
          <button
            id="filter-clear"
            style="display:none"
            class="absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-300 text-lg leading-none"
            aria-label="Clear"
          >×</button>
        </div>
        <span id="filter-summary" class="shrink-0 text-xs text-gray-500 w-24 text-right"></span>
      </div>

      <!-- Ask all videos row -->
      <div>
        <div class="flex items-center gap-3">
          <div id="ask-all-form" class="hidden flex-1 flex gap-2">
            <input
              id="ask-all-input"
              type="text"
              placeholder="Ask a question across all videos…"
              autocomplete="off"
              class="flex-1 px-4 py-2.5 rounded-lg bg-gray-900 border border-indigo-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm"
            />
            <button
              id="ask-all-submit"
              disabled
              class="shrink-0 px-4 py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
            >Ask all</button>
          </div>
          <button
            id="ask-all-toggle"
            class="shrink-0 flex items-center gap-1.5 px-3 py-2 rounded-lg bg-indigo-900/40 hover:bg-indigo-900/70 border border-indigo-700/50 text-indigo-300 text-xs font-medium transition-colors"
          >
            <span>✨</span><span id="ask-all-toggle-label">Ask all videos</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Columns grid -->
    <div class={`grid gap-4 items-start ${videos.length === 3 ? 'grid-cols-1 lg:grid-cols-3' : 'grid-cols-1 md:grid-cols-2'}`}>
      {videos.map((v) => (
        <div class="video-column space-y-0" data-video-id={v.id} data-youtube-id={v.youtube_id}>

          <!-- Column header -->
          <div class="bg-gray-900 rounded-t-xl px-4 pt-4 pb-3 border border-gray-800 border-b-0 space-y-2">
            <div>
              <a
                href={`/video/${v.id}`}
                class="block text-sm font-semibold text-white hover:text-indigo-300 transition-colors leading-snug"
              >
                {v.title}
              </a>
              <p class="text-xs text-gray-500 mt-0.5">
                <span class="col-chunk-count">{v.chunk_count}</span> chunks
                {v.duration_sec && <> · {fmtTime(v.duration_sec)}</>}
                <span class="mx-1.5">·</span>
                <a
                  href={`https://www.youtube.com/watch?v=${v.youtube_id}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-indigo-400 hover:text-indigo-300"
                >YouTube ↗</a>
              </p>
            </div>

            <!-- AI Search (per column) -->
            <div class="border-t border-gray-800 pt-2">
              <div class="flex items-center justify-between gap-2">
                <span class="text-xs text-indigo-300 font-semibold">✨ AI Search</span>
                <button
                  class="ai-toggle shrink-0 px-2.5 py-1 rounded-md bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-medium transition-colors"
                >
                  Ask
                </button>
              </div>
              <div class="ai-form hidden mt-2 space-y-2">
                <div class="flex gap-2">
                  <input
                    type="text"
                    class="ai-input flex-1 px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm"
                    placeholder="Ask a question…"
                    autocomplete="off"
                  />
                  <button
                    class="ai-submit px-3 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
                    disabled
                  >Ask</button>
                </div>
                <p class="ai-status hidden text-xs text-gray-400">Analyzing…</p>
                <p class="ai-error hidden text-xs text-red-400"></p>
                <div class="ai-result hidden space-y-2">
                  <div class="rounded-lg bg-gray-800 border border-gray-700 p-3">
                    <p class="text-xs font-semibold text-indigo-300 mb-1">Answer</p>
                    <p class="ai-answer text-sm text-gray-100 leading-relaxed whitespace-pre-wrap"></p>
                  </div>
                  <div class="ai-sig-chunks space-y-1.5"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Chunk list -->
          <div class="border border-gray-800 border-t-0 rounded-b-xl overflow-hidden">
            <div class="max-h-[65vh] overflow-y-auto divide-y divide-gray-800/60">
              {v.chunks.map((c) => (
                <div
                  class="chunk-row flex gap-3 px-3 py-2.5 hover:bg-gray-800/60 transition-colors"
                  data-text={c.text.toLowerCase()}
                >
                  <a
                    href={`https://www.youtube.com/watch?v=${v.youtube_id}&t=${Math.floor(c.start_sec)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="shrink-0 font-mono text-xs text-indigo-400 hover:text-indigo-300 pt-0.5 w-12"
                  >
                    {fmtTime(c.start_sec)}
                  </a>
                  <p class="chunk-text text-xs text-gray-300 leading-relaxed flex-1" data-raw={c.text}>
                    {c.text}
                  </p>
                </div>
              ))}
              <p class="col-no-results hidden text-xs text-gray-600 text-center py-4">No matches.</p>
            </div>
          </div>

        </div>
      ))}
    </div>
  </div>
</Base>

<script define:vars={{ publicApiBase, videoMetas: videos.map(v => ({ id: v.id, youtube_id: v.youtube_id })) }}>
  // ── Chunk filter ──────────────────────────────────────────────────────────────
  const filterInput = document.getElementById('filter-input');
  const filterClear = document.getElementById('filter-clear');
  const filterSummary = document.getElementById('filter-summary');

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function runFilter() {
    const q = filterInput.value.trim().toLowerCase();
    let totalVisible = 0;
    let totalChunks = 0;

    document.querySelectorAll('.video-column').forEach(col => {
      const rows = col.querySelectorAll('.chunk-row');
      const noResults = col.querySelector('.col-no-results');
      const countEl = col.querySelector('.col-chunk-count');
      let colVisible = 0;

      rows.forEach(row => {
        const text = row.dataset.text ?? '';
        const matches = !q || text.includes(q);
        row.style.display = matches ? '' : 'none';

        const textEl = row.querySelector('.chunk-text');
        if (q && matches) {
          const raw = textEl.dataset.raw ?? '';
          const idx = raw.toLowerCase().indexOf(q);
          if (idx !== -1) {
            textEl.innerHTML =
              escHtml(raw.slice(0, idx)) +
              `<mark class="bg-yellow-400/30 text-yellow-200 rounded px-0.5">${escHtml(raw.slice(idx, idx + q.length))}</mark>` +
              escHtml(raw.slice(idx + q.length));
          }
        } else {
          textEl.textContent = textEl.dataset.raw ?? '';
        }

        if (matches) colVisible++;
      });

      totalVisible += colVisible;
      totalChunks += rows.length;

      if (countEl) countEl.textContent = q ? `${colVisible} / ${rows.length}` : String(rows.length);
      if (noResults) noResults.classList.toggle('hidden', !q || colVisible > 0);
    });

    filterClear.style.display = q ? '' : 'none';
    filterSummary.textContent = q ? `${totalVisible} match${totalVisible !== 1 ? 'es' : ''}` : '';
  }

  filterInput.addEventListener('input', runFilter);
  filterClear.addEventListener('click', () => { filterInput.value = ''; runFilter(); filterInput.focus(); });

  // ── Ask all videos ────────────────────────────────────────────────────────────
  const askAllToggle = document.getElementById('ask-all-toggle');
  const askAllForm = document.getElementById('ask-all-form');
  const askAllInput = document.getElementById('ask-all-input');
  const askAllSubmit = document.getElementById('ask-all-submit');
  const askAllLabel = document.getElementById('ask-all-toggle-label');

  askAllToggle.addEventListener('click', () => {
    const open = !askAllForm.classList.contains('hidden');
    askAllForm.classList.toggle('hidden', open);
    askAllLabel.textContent = open ? 'Ask all videos' : 'Hide';
    if (!open) askAllInput.focus();
  });

  askAllInput.addEventListener('input', () => {
    askAllSubmit.disabled = askAllInput.value.trim().length === 0;
  });

  askAllInput.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !askAllSubmit.disabled) askAllSubmit.click();
  });

  askAllSubmit.addEventListener('click', () => {
    const question = askAllInput.value.trim();
    if (!question) return;
    document.querySelectorAll('.video-column').forEach(col => {
      const form = col.querySelector('.ai-form');
      const toggleBtn = col.querySelector('.ai-toggle');
      const aiInput = col.querySelector('.ai-input');
      const submitBtn = col.querySelector('.ai-submit');
      if (form.classList.contains('hidden')) {
        form.classList.remove('hidden');
        toggleBtn.textContent = 'Hide';
      }
      aiInput.value = question;
      aiInput.dispatchEvent(new Event('input'));
      submitBtn.click();
    });
  });

  // ── Per-column AI Search ──────────────────────────────────────────────────────
  function fmtTime(s) {
    s = Math.floor(s ?? 0);
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    const sec = s % 60;
    const pad = n => String(n).padStart(2, '0');
    return h ? `${h}:${pad(m)}:${pad(sec)}` : `${m}:${pad(sec)}`;
  }

  document.querySelectorAll('.video-column').forEach(col => {
    const videoId = col.dataset.videoId;
    const youtubeId = col.dataset.youtubeId;
    const toggleBtn = col.querySelector('.ai-toggle');
    const form = col.querySelector('.ai-form');
    const aiInput = col.querySelector('.ai-input');
    const submitBtn = col.querySelector('.ai-submit');
    const statusEl = col.querySelector('.ai-status');
    const errEl = col.querySelector('.ai-error');
    const resultEl = col.querySelector('.ai-result');
    const answerEl = col.querySelector('.ai-answer');
    const sigChunksEl = col.querySelector('.ai-sig-chunks');

    toggleBtn.addEventListener('click', () => {
      const open = !form.classList.contains('hidden');
      form.classList.toggle('hidden', open);
      toggleBtn.textContent = open ? 'Ask' : 'Hide';
      if (!open) aiInput.focus();
    });

    aiInput.addEventListener('input', () => {
      submitBtn.disabled = aiInput.value.trim().length === 0;
    });

    aiInput.addEventListener('keydown', e => {
      if (e.key === 'Enter' && !submitBtn.disabled) submitBtn.click();
    });

    submitBtn.addEventListener('click', async () => {
      const question = aiInput.value.trim();
      if (!question) return;

      submitBtn.disabled = true;
      aiInput.disabled = true;
      errEl.classList.add('hidden');
      resultEl.classList.add('hidden');
      statusEl.classList.remove('hidden');
      statusEl.textContent = 'Analyzing…';

      try {
        const token = await window.__getAuthToken();
        const res = await fetch(`${publicApiBase}/api/video/${videoId}/ai-search`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify({ question }),
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(body.detail ?? `HTTP ${res.status}`);

        answerEl.textContent = body.answer ?? '(no answer)';

        sigChunksEl.innerHTML = '';
        for (const c of (body.chunks ?? [])) {
          const card = document.createElement('div');
          card.className = 'flex gap-3 px-3 py-2 rounded-lg bg-gray-800 border border-gray-700';
          card.innerHTML = `
            <a href="https://www.youtube.com/watch?v=${escHtml(youtubeId)}&t=${Math.floor(c.start_sec ?? 0)}"
               target="_blank" rel="noopener noreferrer"
               class="shrink-0 font-mono text-xs text-indigo-400 hover:text-indigo-300 pt-0.5 w-12">
              ${fmtTime(c.start_sec)}
            </a>
            <div class="flex-1 min-w-0 space-y-1">
              <p class="text-xs text-gray-200 leading-relaxed">${escHtml(c.text ?? '')}</p>
              ${c.reason ? `<p class="text-xs text-indigo-300/80 italic">${escHtml(c.reason)}</p>` : ''}
            </div>`;
          sigChunksEl.appendChild(card);
        }

        resultEl.classList.remove('hidden');
      } catch (e) {
        errEl.textContent = e.message ?? 'Request failed';
        errEl.classList.remove('hidden');
      } finally {
        statusEl.classList.add('hidden');
        aiInput.disabled = false;
        submitBtn.disabled = aiInput.value.trim().length === 0;
      }
    });
  });
</script>
