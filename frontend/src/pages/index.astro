---
import Base from '../layouts/Base.astro';
import ChannelForm from '../components/ChannelForm.astro';
import VideoForm from '../components/VideoForm.astro';
import { t } from '../lib/i18n';

const lang = Astro.locals.lang ?? 'en';
const apiBase = import.meta.env.BACKEND_URL ?? 'http://localhost:8000';
let recentChannels: any[] = [];
try {
  const res = await fetch(`${apiBase}/api/channels?limit=50`, { signal: AbortSignal.timeout(500) });
  if (res.ok) {
    const data = await res.json();
    recentChannels = data.channels ?? [];
  }
} catch {}
---
<Base title="Home" description="Add YouTube channels, scrape transcripts, and run AI-powered semantic searches to find the exact moments that match your intent." canonicalPath="/">
  <div class="max-w-2xl mx-auto space-y-10">
    <div class="text-center space-y-2 pt-6">
      <h1 class="text-3xl font-bold text-white">{t(lang, 'home.title')}</h1>
      <p class="text-gray-400">{t(lang, 'home.subtitle')}</p>
    </div>

    <ChannelForm />

    <VideoForm />

    {recentChannels.length > 0 && (
      <div>
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">{t(lang, 'home.channelsHeading')}</h2>
        <ul class="space-y-2">
          {recentChannels.map((c: any) => (
            <li>
              <a
                href={`/channel/${c.id}`}
                class="flex items-center justify-between px-4 py-3 rounded-lg bg-gray-900 hover:bg-gray-800 transition-colors group"
              >
                <span class="text-sm text-gray-200 group-hover:text-white truncate max-w-xs">{c.name ?? c.url}</span>
                <span class="text-xs text-gray-500 ml-4 shrink-0">
                  {c.scraped_count}/{c.video_count} scraped · {c.fetched_at.slice(0,10)}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</Base>
