---
import '../styles/global.css';
import { getLang } from '../lib/i18n';
const lang = getLang(
  Astro.request.headers.get('Cookie') ?? '',
  Astro.request.headers.get('Accept-Language') ?? '',
);
const isIT = lang === 'it';
---
<!doctype html>
<html lang={lang} class="bg-gray-950 text-gray-100 min-h-screen">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{isIT ? 'Privacy Policy — VALE' : 'Privacy Policy — VALE'}</title>
    <meta name="description" content={isIT ? 'Informativa sulla privacy di VALE.' : 'Privacy policy for VALE.'} />
    <meta name="robots" content="noindex" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-gray-800 px-6 py-4 flex items-center gap-4">
      <a href="/" class="flex items-center opacity-80 hover:opacity-100 transition-opacity">
        <img src="/logo.svg" alt="VALE" class="h-4" />
      </a>
    </header>

    <main class="flex-1 px-6 py-12 max-w-3xl mx-auto w-full">
      {isIT ? (
        <>
          <h1 class="text-2xl font-semibold mb-2">Informativa sulla Privacy</h1>
          <p class="text-xs text-gray-500 mb-10">Ultimo aggiornamento: 10 maggio 2026</p>

          <section class="space-y-8 text-sm text-gray-300 leading-relaxed">

            <div>
              <h2 class="text-base font-semibold text-white mb-2">Titolare del trattamento</h2>
              <p>
                Il titolare del trattamento dei dati personali raccolti tramite questo sito è{' '}
                <a href="https://www.andrearapuzzi.com" target="_blank" rel="noopener noreferrer"
                   class="text-indigo-400 hover:text-indigo-300 transition-colors">Andrea Rapuzzi</a>.
              </p>
              <p class="mt-2">
                Per qualsiasi richiesta relativa al trattamento dei tuoi dati personali (accesso, rettifica, cancellazione, portabilità) puoi contattarlo tramite{' '}
                <a href="https://www.linkedin.com/in/andrea-rapuzzi" target="_blank" rel="noopener noreferrer"
                   class="text-indigo-400 hover:text-indigo-300 transition-colors">LinkedIn</a>.
              </p>
            </div>

            <div>
              <h2 class="text-base font-semibold text-white mb-2">Dati raccolti</h2>
              <p>
                VALE raccoglie esclusivamente i dati strettamente necessari al funzionamento del servizio:
              </p>
              <ul class="mt-2 space-y-1 list-disc list-inside text-gray-400">
                <li>Indirizzo email e password (cifrata) per l'autenticazione degli utenti registrati.</li>
                <li>URL di canali YouTube e video aggiunti dall'utente.</li>
                <li>Trascrizioni e metadati dei video recuperati da YouTube.</li>
                <li>Query di ricerca inserite dall'utente.</li>
              </ul>
              <p class="mt-3">
                I dati non vengono venduti né ceduti a terzi per finalità commerciali o pubblicitarie.
              </p>
            </div>

            <div>
              <h2 class="text-base font-semibold text-white mb-2">Cookie</h2>
              <p>
                Questo sito utilizza esclusivamente <strong class="text-white">cookie tecnici</strong>, necessari al funzionamento della piattaforma. Non sono presenti cookie di profilazione, di tracciamento o di terze parti per finalità pubblicitarie.
              </p>
              <ul class="mt-3 space-y-2 list-disc list-inside text-gray-400">
                <li>
                  <strong class="text-gray-200">Cookie di sessione Supabase</strong> — gestiscono l'autenticazione dell'utente. Vengono eliminati alla scadenza della sessione o al logout.
                </li>
                <li>
                  <strong class="text-gray-200">vale-session</strong> — identificatore di sessione anonima, utilizzato per associare le azioni effettuate prima della registrazione all'account dell'utente. Dura 12 mesi.
                </li>
              </ul>
            </div>

            <div>
              <h2 class="text-base font-semibold text-white mb-2">Soluzioni tecniche utilizzate</h2>
              <p class="mb-3">
                Il servizio si avvale delle seguenti tecnologie di terze parti, ciascuna con la propria informativa sulla privacy:
              </p>
              <div class="space-y-3">
                <div class="flex gap-3">
                  <span class="text-gray-200 font-medium w-32 shrink-0">Supabase</span>
                  <span class="text-gray-400">
                    Database e autenticazione. I dati sono ospitati su infrastruttura Supabase (AWS eu-west-1).{' '}
                    <a href="https://supabase.com/privacy" target="_blank" rel="noopener noreferrer"
                       class="text-indigo-400 hover:text-indigo-300 transition-colors">Privacy Policy</a>
                  </span>
                </div>
                <div class="flex gap-3">
                  <span class="text-gray-200 font-medium w-32 shrink-0">Vercel</span>
                  <span class="text-gray-400">
                    Hosting del frontend (interfaccia web).{' '}
                    <a href="https://vercel.com/legal/privacy-policy" target="_blank" rel="noopener noreferrer"
                       class="text-indigo-400 hover:text-indigo-300 transition-colors">Privacy Policy</a>
                  </span>
                </div>
                <div class="flex gap-3">
                  <span class="text-gray-200 font-medium w-32 shrink-0">Railway</span>
                  <span class="text-gray-400">
                    Hosting del backend (API).{' '}
                    <a href="https://railway.app/legal/privacy" target="_blank" rel="noopener noreferrer"
                       class="text-indigo-400 hover:text-indigo-300 transition-colors">Privacy Policy</a>
                  </span>
                </div>
                <div class="flex gap-3">
                  <span class="text-gray-200 font-medium w-32 shrink-0">YouTube / Google</span>
                  <span class="text-gray-400">
                    Recupero di trascrizioni e metadati dei video tramite le API e i tool di YouTube.{' '}
                    <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"
                       class="text-indigo-400 hover:text-indigo-300 transition-colors">Privacy Policy</a>
                  </span>
                </div>
                <div class="flex gap-3">
                  <span class="text-gray-200 font-medium w-32 shrink-0">Anthropic</span>
                  <span class="text-gray-400">
                    Elaborazione AI (Claude) per l'analisi semantica delle trascrizioni e le risposte alle domande.{' '}
                    <a href="https://www.anthropic.com/privacy" target="_blank" rel="noopener noreferrer"
                       class="text-indigo-400 hover:text-indigo-300 transition-colors">Privacy Policy</a>
                  </span>
                </div>
              </div>
            </div>

            <div>
              <h2 class="text-base font-semibold text-white mb-2">Conservazione dei dati</h2>
              <p>
                I dati vengono conservati per il tempo necessario all'erogazione del servizio. Gli utenti possono richiedere la cancellazione del proprio account e di tutti i dati associati contattando il titolare tramite{' '}
                <a href="https://www.linkedin.com/in/andrea-rapuzzi" target="_blank" rel="noopener noreferrer"
                   class="text-indigo-400 hover:text-indigo-300 transition-colors">LinkedIn</a>.
              </p>
            </div>

            <div>
              <h2 class="text-base font-semibold text-white mb-2">Modifiche alla presente informativa</h2>
              <p>
                Il titolare si riserva il diritto di aggiornare questa informativa. La data di ultimo aggiornamento è indicata in cima alla pagina. L'uso continuato del servizio successivo alla pubblicazione delle modifiche costituisce accettazione delle stesse.
              </p>
            </div>

          </section>
        </>
      ) : (
        <>
          <h1 class="text-2xl font-semibold mb-2">Privacy Policy</h1>
          <p class="text-xs text-gray-500 mb-10">Last updated: May 10, 2026</p>

          <section class="space-y-8 text-sm text-gray-300 leading-relaxed">

            <div>
              <h2 class="text-base font-semibold text-white mb-2">Data controller</h2>
              <p>
                The data controller for personal data collected through this website is{' '}
                <a href="https://www.andrearapuzzi.com" target="_blank" rel="noopener noreferrer"
                   class="text-indigo-400 hover:text-indigo-300 transition-colors">Andrea Rapuzzi</a>.
              </p>
              <p class="mt-2">
                For any requests regarding the processing of your personal data (access, correction, deletion, portability) you can contact him via{' '}
                <a href="https://www.linkedin.com/in/andrea-rapuzzi" target="_blank" rel="noopener noreferrer"
                   class="text-indigo-400 hover:text-indigo-300 transition-colors">LinkedIn</a>.
              </p>
            </div>

            <div>
              <h2 class="text-base font-semibold text-white mb-2">Data collected</h2>
              <p>VALE collects only data strictly necessary for the operation of the service:</p>
              <ul class="mt-2 space-y-1 list-disc list-inside text-gray-400">
                <li>Email address and password (hashed) for authentication of registered users.</li>
                <li>YouTube channel and video URLs added by the user.</li>
                <li>Transcripts and metadata of videos retrieved from YouTube.</li>
                <li>Search queries entered by the user.</li>
              </ul>
              <p class="mt-3">Data is never sold or shared with third parties for commercial or advertising purposes.</p>
            </div>

            <div>
              <h2 class="text-base font-semibold text-white mb-2">Cookies</h2>
              <p>
                This website uses only <strong class="text-white">technical cookies</strong> required for the platform to function. There are no profiling, tracking, or third-party advertising cookies.
              </p>
              <ul class="mt-3 space-y-2 list-disc list-inside text-gray-400">
                <li>
                  <strong class="text-gray-200">Supabase session cookies</strong> — manage user authentication. Deleted when the session expires or the user logs out.
                </li>
                <li>
                  <strong class="text-gray-200">vale-session</strong> — anonymous session identifier used to associate actions taken before registration with the user's account. Lasts 12 months.
                </li>
              </ul>
            </div>

            <div>
              <h2 class="text-base font-semibold text-white mb-2">Third-party technologies</h2>
              <p class="mb-3">The service relies on the following third-party technologies, each with their own privacy policy:</p>
              <div class="space-y-3">
                <div class="flex gap-3">
                  <span class="text-gray-200 font-medium w-32 shrink-0">Supabase</span>
                  <span class="text-gray-400">
                    Database and authentication. Data is hosted on Supabase infrastructure (AWS eu-west-1).{' '}
                    <a href="https://supabase.com/privacy" target="_blank" rel="noopener noreferrer"
                       class="text-indigo-400 hover:text-indigo-300 transition-colors">Privacy Policy</a>
                  </span>
                </div>
                <div class="flex gap-3">
                  <span class="text-gray-200 font-medium w-32 shrink-0">Vercel</span>
                  <span class="text-gray-400">
                    Frontend hosting (web interface).{' '}
                    <a href="https://vercel.com/legal/privacy-policy" target="_blank" rel="noopener noreferrer"
                       class="text-indigo-400 hover:text-indigo-300 transition-colors">Privacy Policy</a>
                  </span>
                </div>
                <div class="flex gap-3">
                  <span class="text-gray-200 font-medium w-32 shrink-0">Railway</span>
                  <span class="text-gray-400">
                    Backend hosting (API).{' '}
                    <a href="https://railway.app/legal/privacy" target="_blank" rel="noopener noreferrer"
                       class="text-indigo-400 hover:text-indigo-300 transition-colors">Privacy Policy</a>
                  </span>
                </div>
                <div class="flex gap-3">
                  <span class="text-gray-200 font-medium w-32 shrink-0">YouTube / Google</span>
                  <span class="text-gray-400">
                    Retrieval of video transcripts and metadata via YouTube APIs and tools.{' '}
                    <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"
                       class="text-indigo-400 hover:text-indigo-300 transition-colors">Privacy Policy</a>
                  </span>
                </div>
                <div class="flex gap-3">
                  <span class="text-gray-200 font-medium w-32 shrink-0">Anthropic</span>
                  <span class="text-gray-400">
                    AI processing (Claude) for semantic analysis of transcripts and question answering.{' '}
                    <a href="https://www.anthropic.com/privacy" target="_blank" rel="noopener noreferrer"
                       class="text-indigo-400 hover:text-indigo-300 transition-colors">Privacy Policy</a>
                  </span>
                </div>
              </div>
            </div>

            <div>
              <h2 class="text-base font-semibold text-white mb-2">Data retention</h2>
              <p>
                Data is retained for as long as necessary to provide the service. Users may request deletion of their account and all associated data by contacting the data controller via{' '}
                <a href="https://www.linkedin.com/in/andrea-rapuzzi" target="_blank" rel="noopener noreferrer"
                   class="text-indigo-400 hover:text-indigo-300 transition-colors">LinkedIn</a>.
              </p>
            </div>

            <div>
              <h2 class="text-base font-semibold text-white mb-2">Changes to this policy</h2>
              <p>
                The data controller reserves the right to update this policy. The last updated date is shown at the top of the page. Continued use of the service after changes are published constitutes acceptance of those changes.
              </p>
            </div>

          </section>
        </>
      )}
    </main>

    <footer class="border-t border-gray-800 px-6 py-5 text-center text-xs text-gray-600">
      <a href="/" class="hover:text-gray-400 transition-colors">VALE</a>
      {' · '}
      <a href="https://www.andrearapuzzi.com" target="_blank" rel="noopener noreferrer"
         class="hover:text-gray-400 transition-colors">Andrea Rapuzzi</a>
    </footer>
  </body>
</html>
