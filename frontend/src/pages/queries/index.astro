---
import Base from '../../layouts/Base.astro';

const apiBase = import.meta.env.BACKEND_URL ?? 'http://localhost:8000';
let queries: any[] = [];

try {
  const res = await fetch(`${apiBase}/api/queries?limit=50`);
  if (res.ok) {
    const data = await res.json();
    queries = data.queries ?? [];
  }
} catch {}
---
<Base title="Query History">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-bold text-white">Query History</h1>
      <a href="/query" class="text-sm text-indigo-400 hover:text-indigo-300 transition-colors">+ New Query</a>
    </div>

    {queries.length === 0 ? (
      <p class="text-gray-400 text-sm">No queries yet. <a href="/query" class="text-indigo-400 hover:text-indigo-300">Run your first query →</a></p>
    ) : (
      <div class="space-y-2">
        {queries.map((q: any) => (
          <a
            href={`/query/${q.id}`}
            class="flex items-center justify-between px-5 py-4 rounded-xl bg-gray-900 hover:bg-gray-800 transition-colors group"
          >
            <div class="min-w-0">
              <p class="text-sm text-gray-200 group-hover:text-white truncate">{q.intent}</p>
              <p class="text-xs text-gray-500 mt-0.5">{q.model}</p>
            </div>
            <div class="text-right shrink-0 ml-6">
              <p class="text-sm text-indigo-400 font-medium">{q.result_count} results</p>
              <p class="text-xs text-gray-500">{q.created_at.slice(0,10)}</p>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Base>
