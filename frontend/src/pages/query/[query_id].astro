---
import Base from '../../layouts/Base.astro';
import ProgressPoller from '../../components/ProgressPoller.astro';
import ResultCard from '../../components/ResultCard.astro';

const { query_id } = Astro.params;
const jobId = Astro.url.searchParams.get('job');

const apiBase = import.meta.env.BACKEND_URL ?? 'http://localhost:8000';
const authHeader = { Authorization: `Bearer ${Astro.locals.accessToken}` };

let query: any = null;
let results: any[] = [];
let totalResults = 0;
let jobDone = false;
let error = '';

if (jobId) {
  try {
    const jobRes = await fetch(`${apiBase}/api/query/status/${jobId}`);
    if (jobRes.ok) {
      const job = await jobRes.json();
      jobDone = job.status === 'done' || job.status === 'failed';
    }
  } catch {}
} else {
  jobDone = true;
}

try {
  const res = await fetch(`${apiBase}/api/query/${query_id}/results?limit=200`, { headers: authHeader });
  if (!res.ok) { error = 'Query not found'; }
  else {
    const data = await res.json();
    query = { intent: data.intent, model: data.model, created_at: data.created_at };
    results = data.results;
    totalResults = data.total_results;
  }
} catch (e: any) {
  error = e.message;
}

// Group results by topic, preserving server order.
const groups: { topic: string; items: any[] }[] = [];
const groupIndex = new Map<string, number>();
for (const r of results) {
  const t = r.topic || 'Other';
  let idx = groupIndex.get(t);
  if (idx === undefined) {
    idx = groups.length;
    groupIndex.set(t, idx);
    groups.push({ topic: t, items: [] });
  }
  groups[idx].items.push(r);
}
---
<Base title={query?.intent ?? 'Query'}>
  {error ? (
    <div class="text-red-400">{error}</div>
  ) : (
    <div class="space-y-6">
      <div>
        <h1 class="text-xl font-bold text-white leading-snug">"{query?.intent}"</h1>
        <p class="text-xs text-gray-500 mt-1">{query?.model} · {query?.created_at?.slice(0,10)} · {totalResults} relevant chunks</p>
      </div>

      {!jobDone && jobId && (
        <div class="bg-gray-900 rounded-xl p-5 space-y-3">
          <p class="text-sm text-gray-400 font-medium">Evaluating transcript chunks…</p>
          <ProgressPoller
            jobId={jobId}
            type="query"
            redirectUrl={`/query/${query_id}`}
          />
        </div>
      )}

      {jobDone && results.length === 0 && (
        <p class="text-gray-400 text-sm">No relevant chunks found for this intent across the scraped videos.</p>
      )}

      {results.length > 0 && (
        <div class="space-y-6">
          <div class="flex items-center justify-between">
            <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Results by topic</h2>
            <a
              id="report-link"
              href="#"
              target="_blank"
              class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors"
            >
              Export Markdown ↗
            </a>
            <script define:vars={{ query_id }}>
              const link = document.getElementById('report-link');
              const base = import.meta.env.PUBLIC_BACKEND_URL ?? 'http://localhost:8000';
              link.href = `${base}/api/query/${query_id}/report`;
            </script>
          </div>

          <div class="space-y-8">
            {groups.map(g => (
              <section class="space-y-3">
                <h3 class="text-base font-semibold text-indigo-300 border-b border-gray-800 pb-2">
                  {g.topic}
                  <span class="ml-2 text-xs font-normal text-gray-500">{g.items.length} chunk{g.items.length === 1 ? '' : 's'}</span>
                </h3>
                <div class="space-y-3">
                  {g.items.map((r: any) => (
                    <ResultCard
                      reasoning={r.reasoning}
                      topic={r.topic}
                      chunk_text={r.chunk_text}
                      start_sec={r.start_sec}
                      end_sec={r.end_sec}
                      youtube_id={r.youtube_id}
                      video_title={r.video_title}
                      youtube_url={r.youtube_url}
                    />
                  ))}
                </div>
              </section>
            ))}
          </div>
        </div>
      )}
    </div>
  )}
</Base>
