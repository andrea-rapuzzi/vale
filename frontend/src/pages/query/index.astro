---
import Base from '../../layouts/Base.astro';
const apiBase = import.meta.env.PUBLIC_BACKEND_URL ?? import.meta.env.BACKEND_URL ?? 'http://localhost:8000';

// Pre-selected video ids from query string (e.g. ?v=1&v=2)
const preSelected = Astro.url.searchParams.getAll('v').map(Number);
---
<Base title="New Query">
  <div class="max-w-2xl mx-auto space-y-6">
    <div>
      <h1 class="text-2xl font-bold text-white">New Search Query</h1>
      <p class="text-sm text-gray-400 mt-1">Describe what you're looking for. Claude will identify the transcript chunks that actually discuss the topic.</p>
    </div>

    <form id="query-form" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1.5">Search intent</label>
        <textarea
          id="intent"
          rows="3"
          placeholder="e.g. How to implement rate limiting in Python"
          class="w-full px-4 py-3 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm resize-none"
        ></textarea>
      </div>

      <p id="query-error" class="text-sm text-red-400 hidden"></p>

      <button
        type="submit"
        id="query-btn"
        class="w-full py-3 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Run Query
      </button>
    </form>
  </div>
</Base>

<script define:vars={{ apiBase, preSelected }}>
  const form = document.getElementById('query-form');
  const btn = document.getElementById('query-btn');
  const errEl = document.getElementById('query-error');
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const intent = document.getElementById('intent').value.trim();
    if (!intent) { errEl.textContent = 'Please enter a search intent.'; errEl.classList.remove('hidden'); return; }
    errEl.classList.add('hidden');
    btn.disabled = true;
    btn.textContent = 'Starting…';

    try {
      const body = { intent };
      if (preSelected && preSelected.length) body.video_ids = preSelected;
      const res = await fetch(`${apiBase}/api/query`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${await window.__getAuthToken()}` },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.detail ?? 'Error starting query');
      window.location.href = `/query/${data.query_id}?job=${data.job_id}`;
    } catch (e) {
      errEl.textContent = e.message;
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Run Query';
    }
  });
</script>
