---
import '../styles/global.css';
---
<!doctype html>
<html lang="en" class="bg-gray-950 text-gray-100 min-h-screen">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Register — VALE</title>
    <meta name="description" content="Request access to VALE — AI-powered YouTube transcript search and analysis." />
    <meta property="og:title" content="Register — VALE" />
    <meta property="og:description" content="Request access to VALE — AI-powered YouTube transcript search and analysis." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/open-graph-image.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/open-graph-image.jpg" />
  </head>
  <body class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-sm space-y-6">
      <div class="text-center space-y-1">
        <h1 class="text-2xl font-bold text-white">VALE</h1>
        <p class="text-sm text-gray-400">Request access to the platform</p>
      </div>

      <div id="success-msg" class="hidden rounded-lg bg-green-950 border border-green-800 px-4 py-3 text-sm text-green-300">
        Account created. Your request is pending approval — you'll be able to log in once an admin approves your account.
      </div>

      <form id="register-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1.5">Email</label>
          <input
            id="email"
            type="email"
            autocomplete="email"
            required
            class="w-full px-4 py-2.5 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1.5">Password</label>
          <input
            id="password"
            type="password"
            autocomplete="new-password"
            required
            minlength="8"
            class="w-full px-4 py-2.5 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm"
          />
          <p class="mt-1 text-xs text-gray-500">Minimum 8 characters</p>
        </div>

        <p id="register-error" class="text-sm text-red-400 hidden"></p>

        <button
          type="submit"
          id="register-btn"
          class="w-full py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white font-medium transition-colors disabled:opacity-50 disabled:cursor-not-allowed text-sm"
        >
          Request access
        </button>
      </form>

      <p class="text-center text-sm text-gray-500">
        Already have an account?
        <a href="/login" class="text-indigo-400 hover:text-indigo-300">Sign in</a>
      </p>
    </div>
  </body>
</html>

<script>
  import { createClient } from '../lib/supabase'

  const form = document.getElementById('register-form')!
  const emailEl = document.getElementById('email') as HTMLInputElement
  const passwordEl = document.getElementById('password') as HTMLInputElement
  const errEl = document.getElementById('register-error')!
  const successEl = document.getElementById('success-msg')!
  const btn = document.getElementById('register-btn') as HTMLButtonElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errEl.classList.add('hidden')
    btn.disabled = true
    btn.textContent = 'Sending request…'

    const supabase = createClient()
    const { error } = await supabase.auth.signUp({
      email: emailEl.value.trim(),
      password: passwordEl.value,
    })

    if (error) {
      errEl.textContent = error.message
      errEl.classList.remove('hidden')
      btn.disabled = false
      btn.textContent = 'Request access'
      return
    }

    form.classList.add('hidden')
    successEl.classList.remove('hidden')
  })
</script>
