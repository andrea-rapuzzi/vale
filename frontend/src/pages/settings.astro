---
import Base from '../layouts/Base.astro';
import CookiesUploadForm from '../components/CookiesUploadForm.astro';
import { t } from '../lib/i18n';
const lang = Astro.locals.lang ?? 'en';
---
<Base title={t(lang, 'settings.title')}>
  <div class="space-y-8">
    <h1 class="text-2xl font-bold text-white">{t(lang, 'settings.title')}</h1>

    <div class="bg-gray-900 rounded-xl p-6 space-y-4">
      <h2 class="text-lg font-semibold text-white">{t(lang, 'settings.languageHeading')}</h2>
      <p class="text-sm text-gray-400">{t(lang, 'settings.languageDesc')}</p>
      <div class="flex gap-3" id="lang-switcher" data-current={lang}>
        <button
          data-lang="en"
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors border ${lang === 'en' ? 'bg-indigo-600 border-indigo-500 text-white' : 'bg-gray-800 border-gray-700 text-gray-300 hover:bg-gray-700'}`}
        >
          {t(lang, 'settings.langEn')}
        </button>
        <button
          data-lang="it"
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors border ${lang === 'it' ? 'bg-indigo-600 border-indigo-500 text-white' : 'bg-gray-800 border-gray-700 text-gray-300 hover:bg-gray-700'}`}
        >
          {t(lang, 'settings.langIt')}
        </button>
      </div>
    </div>

    <CookiesUploadForm />
  </div>
</Base>

<script>
  document.querySelectorAll<HTMLButtonElement>('#lang-switcher [data-lang]').forEach(btn => {
    btn.addEventListener('click', () => {
      const newLang = btn.dataset.lang!
      document.cookie = `vale-lang=${newLang}; path=/; max-age=31536000; samesite=lax`
      window.location.reload()
    })
  })
</script>
