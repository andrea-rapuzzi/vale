---
import Base from '../../layouts/Base.astro';

const { id } = Astro.params;
const apiBase = import.meta.env.BACKEND_URL ?? 'http://localhost:8000';
const publicApiBase = import.meta.env.PUBLIC_BACKEND_URL ?? 'http://localhost:8000';

let data: any = null;
let error = '';
try {
  const res = await fetch(`${apiBase}/api/video/${id}/transcript`);
  if (!res.ok) {
    const body = await res.json().catch(() => ({}));
    error = body.detail ?? `HTTP ${res.status}`;
  } else {
    data = await res.json();
  }
} catch (e: any) {
  error = e.message;
}

function fmtTime(s: number) {
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  const sec = Math.floor(s % 60);
  if (h) return `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
  return `${m}:${String(sec).padStart(2,'0')}`;
}
---
<Base title={data?.title ?? 'Transcript'}>
  {error ? (
    <div class="text-red-400">{error}</div>
  ) : (
    <div class="space-y-6 max-w-3xl">
      <div class="space-y-2">
        <a href={`/channel/${data.channel_id}`} class="text-xs text-indigo-400 hover:text-indigo-300">
          ← {data.channel_name}
        </a>
        <h1 class="text-2xl font-bold text-white">{data.title}</h1>
        <div class="flex items-center gap-3 text-xs text-gray-500">
          <span id="chunk-count">{data.chunks.length} chunks</span>
          {data.duration_sec && <span>· {fmtTime(data.duration_sec)}</span>}
          <a
            href={`https://www.youtube.com/watch?v=${data.youtube_id}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-indigo-400 hover:text-indigo-300"
          >
            ▶ Open on YouTube
          </a>
        </div>
      </div>

      {/* AI Search */}
      <div class="rounded-lg border border-indigo-800/60 bg-indigo-950/20 p-4 space-y-3">
        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-2">
            <span class="text-indigo-300 text-sm font-semibold">✨ AI Search</span>
            <span class="text-xs text-gray-500">Ask a question; Claude analyzes the transcript and points you to the moments that matter.</span>
          </div>
          <button
            id="ai-toggle"
            class="shrink-0 px-3 py-1.5 rounded-md bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-medium transition-colors"
          >
            AI Search
          </button>
        </div>

        <div id="ai-form" class="hidden space-y-3">
          <div class="flex gap-2">
            <input
              id="ai-input"
              type="text"
              placeholder="Ask a question about this video…"
              autocomplete="off"
              class="flex-1 px-4 py-2.5 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm"
            />
            <button
              id="ai-submit"
              disabled
              class="px-4 py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
            >
              Ask
            </button>
          </div>

          <p id="ai-status" class="hidden text-sm text-gray-400">Analyzing transcript…</p>
          <p id="ai-error" class="hidden text-sm text-red-400"></p>

          <div id="ai-result" class="hidden space-y-4">
            <div class="rounded-lg bg-gray-900 border border-gray-800 p-4">
              <h3 class="text-xs font-semibold uppercase tracking-wider text-indigo-300 mb-2">Answer</h3>
              <p id="ai-answer" class="text-sm text-gray-100 leading-relaxed whitespace-pre-wrap"></p>
            </div>

            <div id="ai-chunks-wrap" class="space-y-2">
              <h3 class="text-xs font-semibold uppercase tracking-wider text-indigo-300">Most significant chunks</h3>
              <div id="ai-chunks" class="space-y-2"></div>
              <p id="ai-no-chunks" class="hidden text-xs text-gray-500">No specific chunks were highlighted for this answer.</p>
            </div>
          </div>
        </div>
      </div>

      {/* Search bar */}
      <div class="sticky top-0 z-10 bg-gray-950 py-3 border-b border-gray-800">
        <div class="flex items-center gap-3">
          <div class="relative flex-1">
            <input
              id="search-input"
              type="text"
              placeholder="Filter chunks…"
              autocomplete="off"
              class="w-full px-4 py-2.5 pr-9 rounded-lg bg-gray-900 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm"
            />
            <button
              id="clear-btn"
              style="display:none"
              class="absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-300 text-lg leading-none"
              aria-label="Clear search"
            >×</button>
          </div>
          <span id="match-count" class="shrink-0 text-xs text-gray-500 w-20 text-right"></span>
        </div>
      </div>

      {/* Chunk list */}
      <div class="space-y-2">
        {data.chunks.map((c: any) => (
          <div
            class="chunk-row flex gap-4 px-4 py-3 rounded-lg bg-gray-900 hover:bg-gray-800 transition-colors"
            data-text={c.text.toLowerCase()}
          >
            <a
              href={`https://www.youtube.com/watch?v=${data.youtube_id}&t=${Math.floor(c.start_sec)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 font-mono text-xs text-indigo-400 hover:text-indigo-300 pt-0.5 w-16"
            >
              {fmtTime(c.start_sec)}
            </a>
            <p class="chunk-text text-sm text-gray-200 leading-relaxed flex-1" data-raw={c.text}>{c.text}</p>
          </div>
        ))}
      </div>

      <p id="no-results" class="hidden text-sm text-gray-500 text-center py-8">
        Nessun chunk corrisponde alla ricerca.
      </p>
    </div>
  )}
</Base>

<script>
  const input = document.getElementById('search-input') as HTMLInputElement | null;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement | null;
  const matchCount = document.getElementById('match-count')!;
  const noResults = document.getElementById('no-results')!;
  const chunkCount = document.getElementById('chunk-count')!;
  const rows = document.querySelectorAll('.chunk-row');
  const total = rows.length;

  function escapeHtml(str: string) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function filter() {
    if (!input) return;
    const q = input.value.trim().toLowerCase();
    let visible = 0;

    rows.forEach(row => {
      const el = row as HTMLElement;
      const text = el.dataset.text!;
      const matches = !q || text.includes(q);
      el.style.display = matches ? '' : 'none';

      const textEl = el.querySelector('.chunk-text') as HTMLElement;
      if (q && matches) {
        const raw = textEl.dataset.raw!;
        const idx = raw.toLowerCase().indexOf(q);
        if (idx !== -1) {
          textEl.innerHTML =
            escapeHtml(raw.slice(0, idx)) +
            `<mark class="bg-yellow-400/30 text-yellow-200 rounded px-0.5">${escapeHtml(raw.slice(idx, idx + q.length))}</mark>` +
            escapeHtml(raw.slice(idx + q.length));
        }
      } else {
        textEl.textContent = textEl.dataset.raw!;
      }

      if (matches) visible++;
    });

    if (q) {
      matchCount.textContent = `${visible} match${visible !== 1 ? 'es' : ''}`;
      chunkCount.textContent = `${visible} / ${total} chunks`;
    } else {
      matchCount.textContent = '';
      chunkCount.textContent = `${total} chunks`;
    }

    if (clearBtn) clearBtn.style.display = q ? '' : 'none';
    noResults?.classList.toggle('hidden', !q || visible > 0);
  }

  if (input) {
    input.addEventListener('input', filter);
    clearBtn?.addEventListener('click', () => { input.value = ''; filter(); input.focus(); });
  }
</script>

<script define:vars={{ publicApiBase, videoId: id, youtubeId: data?.youtube_id }}>
  const toggleBtn = document.getElementById('ai-toggle');
  const form = document.getElementById('ai-form');
  const aiInput = document.getElementById('ai-input');
  const submitBtn = document.getElementById('ai-submit');
  const statusEl = document.getElementById('ai-status');
  const errEl = document.getElementById('ai-error');
  const resultEl = document.getElementById('ai-result');
  const answerEl = document.getElementById('ai-answer');
  const chunksEl = document.getElementById('ai-chunks');
  const noChunksEl = document.getElementById('ai-no-chunks');

  if (toggleBtn && form && aiInput && submitBtn) {
    toggleBtn.addEventListener('click', () => {
      const open = !form.classList.contains('hidden');
      if (open) {
        form.classList.add('hidden');
        toggleBtn.textContent = 'AI Search';
      } else {
        form.classList.remove('hidden');
        toggleBtn.textContent = 'Hide';
        aiInput.focus();
      }
    });

    aiInput.addEventListener('input', () => {
      submitBtn.disabled = aiInput.value.trim().length === 0;
    });

    aiInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !submitBtn.disabled) {
        e.preventDefault();
        submitBtn.click();
      }
    });

    function fmtTime(s) {
      s = Math.floor(s);
      const h = Math.floor(s / 3600);
      const m = Math.floor((s % 3600) / 60);
      const sec = s % 60;
      const pad = (n) => String(n).padStart(2, '0');
      return h ? `${h}:${pad(m)}:${pad(sec)}` : `${m}:${pad(sec)}`;
    }

    function escapeHtml(str) {
      return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    submitBtn.addEventListener('click', async () => {
      const question = aiInput.value.trim();
      if (!question) return;

      submitBtn.disabled = true;
      aiInput.disabled = true;
      errEl.classList.add('hidden');
      resultEl.classList.add('hidden');
      statusEl.classList.remove('hidden');

      try {
        const res = await fetch(`${publicApiBase}/api/video/${videoId}/ai-search`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question }),
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(body.detail ?? `HTTP ${res.status}`);

        answerEl.textContent = body.answer || '(no answer)';
        chunksEl.innerHTML = '';
        const chunks = Array.isArray(body.chunks) ? body.chunks : [];
        if (chunks.length === 0) {
          noChunksEl.classList.remove('hidden');
        } else {
          noChunksEl.classList.add('hidden');
          for (const c of chunks) {
            const card = document.createElement('div');
            card.className = 'flex gap-4 px-4 py-3 rounded-lg bg-gray-900 border border-gray-800';
            card.innerHTML = `
              <a
                href="https://www.youtube.com/watch?v=${escapeHtml(youtubeId)}&t=${Math.floor(c.start_sec)}"
                target="_blank"
                rel="noopener noreferrer"
                class="shrink-0 font-mono text-xs text-indigo-400 hover:text-indigo-300 pt-0.5 w-16"
              >${fmtTime(c.start_sec)}</a>
              <div class="flex-1 min-w-0 space-y-1.5">
                <p class="text-sm text-gray-200 leading-relaxed">${escapeHtml(c.text)}</p>
                ${c.reason ? `<p class="text-xs text-indigo-300/80 italic">${escapeHtml(c.reason)}</p>` : ''}
              </div>
            `;
            chunksEl.appendChild(card);
          }
        }

        resultEl.classList.remove('hidden');
      } catch (e) {
        errEl.textContent = e.message ?? 'Request failed';
        errEl.classList.remove('hidden');
      } finally {
        statusEl.classList.add('hidden');
        aiInput.disabled = false;
        submitBtn.disabled = aiInput.value.trim().length === 0;
      }
    });
  }
</script>
